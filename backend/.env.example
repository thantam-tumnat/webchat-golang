# คัดลอกไฟล์นี้เป็น .env แล้วปรับค่าได้ตามต้องการ
#   cp .env.example .env   (mac/linux)
#   copy .env.example .env (windows)

# พอร์ตที่ backend จะรัน
APP_PORT=8080

# การเชื่อมต่อ PostgreSQL (ค่า default ตรงกับ docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USER=chatapp
DB_PASSWORD=chatapp
DB_NAME=chatapp
DB_SSLMODE=disable

# origin ของ frontend ที่อนุญาตให้เรียก API (CORS)
CORS_ORIGINS=http://localhost:5173
